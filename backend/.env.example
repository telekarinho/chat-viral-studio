# ─── Chat Viral Studio · Backend ───────────────────────────────
PORT=4000

# Frontend origin allowed by CORS (web dev server)
CORS_ORIGIN=http://localhost:3000

# Google Gemini (https://aistudio.google.com/app/apikey)
# Sem chave, o backend usa um gerador MOCK local (tudo funciona offline).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Google Cloud Text-to-Speech (https://console.cloud.google.com/apis/credentials)
# API key simples (Cloud TTS). Sem chave, /api/tts retorna um beep sintetizado.
GOOGLE_TTS_API_KEY=

# FFmpeg binary (deixe "ffmpeg" se estiver no PATH)
FFMPEG_PATH=ffmpeg

# SQLite file
DB_PATH=./data/projects.db

# Where uploaded WebM / rendered MP4 are stored
MEDIA_DIR=./data/media
